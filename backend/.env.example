# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dataset_manager

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
